<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_transitops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="sequence">20</field>
        </record>

        <record model="res.groups.privilege" id="res_groups_privilege_transitops">
            <field name="name">TransitOps</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="module_category_transitops"/>
        </record>

        <!-- Fleet Manager: oversees fleet assets, maintenance, lifecycle -->
        <record id="group_transitops_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_transitops"/>
            <field name="implied_ids" eval="[(4, ref('fleet.fleet_group_manager'))]"/>
        </record>

        <!-- Dispatcher: named "Driver" persona in the spec — creates trips,
             assigns vehicles/drivers, monitors active deliveries -->
        <record id="group_transitops_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="privilege_id" ref="res_groups_privilege_transitops"/>
            <field name="implied_ids" eval="[(4, ref('fleet.fleet_group_user'))]"/>
        </record>

        <!-- Safety Officer: license/compliance/safety score visibility -->
        <record id="group_transitops_safety_officer" model="res.groups">
            <field name="name">Safety Officer</field>
            <field name="privilege_id" ref="res_groups_privilege_transitops"/>
        </record>

        <!-- Financial Analyst: expense/fuel/maintenance cost visibility -->
        <record id="group_transitops_financial_analyst" model="res.groups">
            <field name="name">Financial Analyst</field>
            <field name="privilege_id" ref="res_groups_privilege_transitops"/>
            <field name="implied_ids" eval="[(4, ref('hr_expense.group_hr_expense_user'))]"/>
        </record>

    </data>
</odoo>
