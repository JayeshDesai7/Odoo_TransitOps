<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_trip_list" model="ir.ui.view">
        <field name="name">fleet.trip.list</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <list decoration-info="state=='draft'" decoration-success="state=='completed'"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_trip_form" model="ir.ui.view">
        <field name="name">fleet.trip.form</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_dispatch" type="object" string="Dispatch"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_complete" type="object" string="Complete"
                            class="oe_highlight" invisible="state != 'dispatched'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('completed', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,dispatched,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="source"/>
                            <field name="destination"/>
                            <field name="vehicle_id"
                                   readonly="state != 'draft'"/>
                            <field name="driver_id"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="cargo_weight"/>
                            <field name="planned_distance"/>
                            <field name="revenue"
                                   groups="transitops.group_transitops_financial_analyst,transitops.group_transitops_fleet_manager"/>
                            <field name="final_odometer"
                                   invisible="state not in ('dispatched', 'completed')"/>
                            <field name="fuel_consumed"
                                   invisible="state not in ('dispatched', 'completed')"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fleet_trip_kanban" model="ir.ui.view">
        <field name="name">fleet.trip.kanban</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <strong><field name="name"/></strong>
                            <div><field name="source"/> &#8594; <field name="destination"/></div>
                            <div><field name="vehicle_id"/> / <field name="driver_id"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_fleet_trip" model="ir.actions.act_window">
        <field name="name">Trips</field>
        <field name="res_model">fleet.trip</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>
